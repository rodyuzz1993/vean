---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";


import CardElement from "../snippets/CardElement.astro";
import ImagenResponsive from "../snippets/ImagenResponsive.astro";
import ListElement from "../snippets/ListElement.astro";



import Formulario from "../components/Formulario.astro";
import { site } from "../data/site";
