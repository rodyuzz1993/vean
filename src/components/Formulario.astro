---
import { preguntas, boton } from "../data/formulario";
---

<section id="formulario" class="section">

  <h2>Formulario</h2>

  <form
    name="vean-contacto"
    method="POST"
    action={boton[0].paginaGracias}
    data-netlify="true"
    netlify-honeypot="bot-field"
  >

    {/* NECESARIO PARA NETLIFY */}
    <input
      type="hidden"
      name="form-name"
      value="vean-contacto"
    />

    {/* ANTISPAM */}
    <p hidden>
      <label>
        No llenar:
        <input name="bot-field" />
      </label>
    </p>

    <article class="preguntas">

      {/* 🔼 CAMPOS INPUT / SELECT */}
      <div class="grupo-arriba">

        {preguntas
          .filter(item =>
            item.type === "text" ||
            item.type === "email" ||
            item.type === "tel"
          )
          .map((item, index) => (

            <div class="grupo-input">

              <label for={`campo-${index}`}>
                {item.label}
              </label>

              <input
                id={`campo-${index}`}
                name={item.name}
                type={item.type}
                required={item.required}
              />

            </div>

          ))}

        {/* SELECT */}
        {preguntas
          .filter(item => item.type === "select")
          .map((item, index) => (

            <div class="grupo-input">

              <label for={`campo-select-${index}`}>
                {item.label}
              </label>

              <select
                id={`campo-select-${index}`}
                name={item.name}
                required={item.required}
              >

                {item.opciones.map((opt, i) => (

                  <option
                    value={opt.valor}
                    disabled={i === 0}
                    selected={i === 0}
                    hidden={i === 0}
                  >
                    {opt.opcion}
                  </option>

                ))}

              </select>

            </div>

          ))}

      </div>

      {/* 🔽 TEXTAREA + CHECKBOX */}
      <div class="grupo-abajo">

        {/* TEXTAREA */}
        {preguntas
          .filter(item => item.type === "textarea")
          .map((item, index) => (

            <div class="grupo-input">

              <label for={`campo-textarea-${index}`}>
                {item.label}
              </label>

              <textarea
                id={`campo-textarea-${index}`}
                name={item.name}
                required={item.required}
              ></textarea>

            </div>

          ))}

        {/* CHECKBOX */}
        {preguntas
          .filter(item => item.type === "checkbox")
          .map((item, index) => (

            <div class="grupo-input">

              <label class="checkbox">

                <input
                  type="checkbox"
                  name={item.name}
                  value="aceptado"
                  required={item.required}
                />

                <small>
                  {item.label}{" "}
                </small>

                <button
                  type="button"
                  class="aceptar-terminos"
                  data-url={item.urlPoliticas}
                >
                  <small>
                    {item.textoPolitica}
                  </small>
                </button>

              </label>

            </div>

          ))}

      </div>

      {/* MODAL */}
      <div id="modal-terminos" class="modal-terminos">

        <div class="modal-contenido-terminos">

          <button
            type="button"
            class="cerrar"
          >
            ✕
          </button>

          <iframe
            id="iframe-terminos"
            src=""
            width="100%"
            height="400"
            style="border:none;"
          ></iframe>

        </div>

      </div>

    </article>

    {/* TEXTO */}
    <p class="form-texto">
      Compártenos los datos generales de tu proyecto y un especialista de VEAN te contactará para revisar tus necesidades técnicas.
    </p>

    {/* BOTÓN */}
    <button
      type="submit"
      class="enviar"
    >

      {boton[0].cta}

      <i class="fa-solid fa-paper-plane"></i>

    </button>

  </form>

</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {

    const modal =
      document.getElementById("modal-terminos");

    const iframe =
      document.getElementById("iframe-terminos");

    document.addEventListener("click", (e) => {

      const btn =
        e.target.closest(".aceptar-terminos");

      if (btn) {

        iframe.src = btn.dataset.url;

        modal.style.display = "flex";

      }

      if (
        e.target.closest(".cerrar") ||
        e.target === modal
      ) {

        modal.style.display = "none";

        iframe.src = "";

      }

    });

  });
</script>